{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "XyMusic",
  "version": "0.1.1",
  "identifier": "com.xymusic.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "XyMusic",
        "width": 1280,
        "height": 800,
        "minWidth": 1000,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "center": true
      },
      {
        "label": "desktop-lyrics",
        "title": "XyMusic 桌面歌词",
        "url": "index.html?window=desktop-lyrics",
        "width": 900,
        "height": 180,
        "minWidth": 480,
        "minHeight": 100,
        "maxWidth": 1600,
        "maxHeight": 420,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "center": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "shortDescription": "面向个人音乐库的桌面客户端",
    "longDescription": "XyMusic Windows 桌面客户端",
    "copyright": "Copyright © 2026 muchen",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
